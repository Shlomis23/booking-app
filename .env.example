# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Resend (server-side only — set in Supabase Edge Function secrets)
RESEND_API_KEY=re_...

# Admin (set in Supabase Edge Function secrets)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_FROM_EMAIL=booking@yourcompany.com
ADMIN_PASSWORD=your-secure-password

# App URL (for email links — set in Supabase Edge Function secrets)
APP_URL=https://your-app.netlify.app
